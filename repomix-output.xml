@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  /* Dark Theme Base Tokens */
  --bg: #0a0a0a;
  --text: #a1a1aa;
  --text-h: #ffffff;
  --border: rgba(255, 255, 255, 0.08);
  --accent: #aa3bff;
  --accent-bg: rgba(170, 59, 255, 0.1);
  --accent-border: rgba(170, 59, 255, 0.5);
  
  --shadow: rgba(0, 0, 0, 0.5) 0 10px 15px -3px, rgba(0, 0, 0, 0.3) 0 4px 6px -2px;

  /* Typography - Updated to Premium Fonts */
  --sans: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
  --heading: 'Playfair Display', serif;
  --mono: ui-monospace, Consolas, monospace;

  /* Base Settings */
  font: 16px/145% var(--sans);
  letter-spacing: 0.18px;
  color-scheme: dark;
  color: var(--text);
  background: var(--bg);
  
  font-synthesis: none;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* Remove default browser margins */
body {
  margin: 0;
  background: #0a0a0a;
  overscroll-behavior-y: none;
}

/* RESPONSIVE IMAGE FIXES */
img {
  max-width: 100%;
  height: auto;
  display: block;
}

/* Root container */
#root {
  width: 100%;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow-x: hidden;
}

code,
.counter {
  font-family: var(--mono);
  display: inline-flex;
  border-radius: 4px;
  color: var(--text-h);
}

code {
  font-size: 15px;
  line-height: 135%;
  padding: 4px 8px;
  background: rgba(255, 255, 255, 0.05);
}

/* Selectable Text Fixes */
::selection {
  background: var(--accent-bg);
  color: var(--text-h);
}

/* Scrollbar Styling for cleaner look */
::-webkit-scrollbar {
  width: 6px;
}
::-webkit-scrollbar-track {
  background: var(--bg);
}
::-webkit-scrollbar-thumb {
  background: #333;
