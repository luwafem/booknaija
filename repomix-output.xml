        <ProductCard
          key={p.id}
          product={p}
          active={selectedProducts.includes(p.id)}
          accent={accent}
          onClick={(id, size, color) => onSelect(id, size, color)}
          location={location}
          theme={theme}
        />
      ))}
    </div>
  );
}

function ProductCard({ product, active, accent, onClick, location, theme }) {
