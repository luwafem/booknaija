                    >
                      {b.status}
                    </span>
                  </div>
                  <p className="text-xs text-zinc-300 mb-1">{b.order_summary}</p>
                  <div className="flex flex-wrap gap-x-4 gap-y-1 text-[11px] text-zinc-500 mt-2">
