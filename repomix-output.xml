    cacheName: 'supabase-api',
    plugins: [
      new ExpirationPlugin({
        maxEntries: 50,
        maxAgeSeconds: 60 * 60 * 24, // 1 day
      }),
    ],
  })
);

// Optional: Handle fetch errors (offline fallback)
self.addEventListener('fetch', (event) => {
  // You can add custom logic here if needed
