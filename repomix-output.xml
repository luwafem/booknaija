            <div className={`flex items-center gap-1.5 px-4 py-3 border-b ${T.borderSub} ${T.urlBar}`}>
              <div className="flex gap-1">
                <div className={`w-2.5 h-2.5 rounded-full ${T.dot}`} />
                <div className={`w-2.5 h-2.5 rounded-full ${T.dot}`} />
